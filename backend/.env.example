# --- AI + data providers ---
GEMINI_API_KEY=your_gemini_key_here
USDA_API_KEY=your_usda_key_here
# Wearable sync now uses the Google Health API (the old Fitbit Web API was retired
# and folded into Google Cloud). Reuse the same Google OAuth client as sign-in,
# or create a dedicated one. The old FITBIT_* names still work as a fallback.
GOOGLE_HEALTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_HEALTH_CLIENT_SECRET=your_google_oauth_client_secret

# --- Deployment (leave unset for local dev) ---
# Comma-separated frontend origins allowed by CORS.
# e.g. https://bio-twin-ai.vercel.app
ALLOWED_ORIGINS=http://localhost:3000
# Public URL of THIS backend (used for the Google Health OAuth callback).
BACKEND_URL=http://localhost:8000
# Public URL of the frontend (where users return after OAuth).
FRONTEND_URL=http://localhost:3000
# Optional: Postgres connection string for production.
# Leave unset to use a local SQLite file.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
